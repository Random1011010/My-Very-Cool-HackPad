{
    "manufacturer": "Adhyan Mahindru",
    "keyboard_name": "myverycoolpad",
    "maintainer": "Random1011010",
    "url": "https://github.com/Random1011010/myverycoolpad",
    "bootloader": "rp2040",
    "diode_direction": "COL2ROW",
    "bootmagic": {
        "matrix": [0, 0]
    },
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": false,
        "nkro": true,
        "encoder": true,
        "oled": true
    },
    "matrix_pins": {
        "cols": ["GP29", "GP0", "GP3"],
        "rows": ["GP26", "GP27"]
    },
    "encoder": {
        "rotary": [
            {"pin_a": "GP2", "pin_b": "GP1", "resolution": 4}
        ]
    },
    "i2c": {
        "sda_pin": "GP6",
        "scl_pin": "GP7"
    },
    "processor": "RP2040",
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0001",
        "vid": "0xFEED"
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1}
            ]
        }
    }
}
